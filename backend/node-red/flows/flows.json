    {
        "id": "3174a37c1da3fe54",
        "type": "function",
        "z": "09334837b5d4810d",
        "name": "Twilio config",
        "func": "// Validar datos\nconst d = msg.payload;\n\nif (\n    typeof d.Temperatura !== \"number\" ||\n    typeof d.Humedad !== \"number\" ||\n    typeof d.Viento !== \"number\"\n) {\n    return null;\n}\n\n// Fecha Colombia\nconst fecha = new Date().toLocaleString(\"es-CO\", {\n    timeZone: \"America/Bogota\"\n});\n\n// Construir mensaje WhatsApp\nconst alertMessage = `*ALERTA DE HELADA*\n\n *Temperatura:* ${d.Temperatura.toFixed(1)} °C\n *Humedad:* ${d.Humedad.toFixed(1)} %\n *Viento:* ${d.Viento.toFixed(1)} m/s\n\n Nodo: ${d.Device_id}\n ${fecha}\n\n⚠ Alta probabilidad de helada.\nSe recomienda encender aspersores.`;\n\n// ===== CONFIGURACIÓN TWILIO =====\nconst accountSid = \"tu_sid\";\nconst authToken = \"tu_token\";\n\nmsg.url = `https://api.twilio.com/2010-04-01/Accounts/${accountSid}/Messages.json`;\n\nmsg.headers = {\n    \"Content-Type\": \"application/x-www-form-urlencoded\",\n    \"Authorization\": \"Basic \" + Buffer.from(accountSid + \":\" + authToken).toString(\"base64\")\n};\n\nmsg.method = \"POST\";\n\n// Datos del mensaje\nconst messageData = {\n    \"Body\": alertMessage,\n    \"From\": \"whatsapp:+14155238886\",      // Sandbox Twilio\n    \"To\": \"whatsapp:+57\"        // Tu número\n};\n\n// Convertir a form-urlencoded\nlet formData = '';\nfor (const key in messageData) {\n    if (formData.length) formData += '&';\n    formData += encodeURIComponent(key) + '=' + encodeURIComponent(messageData[key]);\n}\n\nmsg.payload = formData;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1110,
        "y": 200,
        "wires": [

    {
        "id": "3b4ec8f9d3fb2ab5",
        "type": "function",
        "z": "09334837b5d4810d",
        "name": "uplinktoinfluxdbout+power",
        "func": "// Verificar uplink válido\nif (\n    !msg.payload ||\n    !msg.payload.uplink_message ||\n    !msg.payload.uplink_message.decoded_payload\n) {\n    return null;\n}\n\nconst decoded = msg.payload.uplink_message.decoded_payload;\nconst deviceId = msg.payload.end_device_ids.device_id;\n\n// Obtener RSSI y SNR\nlet rssi = null;\nlet snr = null;\n\nif (\n    msg.payload.uplink_message.rx_metadata &&\n    msg.payload.uplink_message.rx_metadata.length > 0\n) {\n    rssi = msg.payload.uplink_message.rx_metadata[0].rssi;\n    snr = msg.payload.uplink_message.rx_metadata[0].snr;\n}\n\n// Measurement dinámico por nodo\nmsg.measurement = deviceId;\n\n// Copiar TODAS las variables del payload decodificado\nlet payload = {};\n\nfor (let key in decoded) {\n    payload[key] = Number(decoded[key]);\n}\n\n// Agregar RSSI y SNR\npayload.RSSI = Number(rssi);\npayload.SNR = Number(snr);\n\n// Enviar a InfluxDB\nmsg.payload = payload;\n\n// Mostrar TODO en debug\nnode.warn({\n    device: deviceId,\n    ...payload\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",

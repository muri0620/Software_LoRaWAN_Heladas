    {
        "id": "5fb7228965a6baac",
        "type": "function",
        "z": "09334837b5d4810d",
        "d": true,
        "name": "Evaluar condición de helada",
        "func": "const d = msg.payload;\n\n// Validar existencia y que sean números válidos\nif (\n    typeof d.Temperatura !== \"number\" ||\n    typeof d.Humedad !== \"number\" ||\n    typeof d.Viento !== \"number\"\n) {\n    return null;\n}\n\n// Ahora sí evaluar condición\nif (d.Temperatura <= 2 && d.Humedad <= 50 && d.Viento <= 5) {\n\n    msg.text = `🚨 ALERTA DE HELADA 🚨\nNodo: ${d.Device_id}\nTemperatura: ${d.Temperatura} °C\nHumedad: ${d.Humedad} %\nViento: ${d.Viento} m/s\n${new Date().toLocaleString(\"es-CO\")}`;\n\n    return msg;\n}\n\nreturn null;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 280,
        "wires": [

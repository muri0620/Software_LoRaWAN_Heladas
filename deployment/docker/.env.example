# =====================================================================
# Variables de entorno para el sistema IoT LoRaWAN - Heladas
# Copia este archivo a `.env` y reemplaza los valores antes de levantar
# los contenedores con `docker compose up -d`.
# NUNCA versionar el archivo `.env` real (ya está en .gitignore).
# =====================================================================

# --- InfluxDB 2.x ---
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=cambiar-por-password-fuerte
INFLUXDB_ORG=wsn-heladas
INFLUXDB_BUCKET=sensores
# Token administrativo inicial (generar uno aleatorio y largo)
INFLUXDB_ADMIN_TOKEN=cambiar-por-token-aleatorio

# --- Cloudflared Tunnel ---
# Token del túnel creado en el dashboard de Cloudflare Zero Trust
CLOUDFLARED_TOKEN=cambiar-por-token-cloudflared

# --- Zona horaria de los contenedores ---
TZ=America/Bogota
